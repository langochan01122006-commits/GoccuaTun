rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Default safety net (deny all by default)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidVote(data) {
      return (data.characterId == null || (data.characterId is string && data.characterId.size() <= 64))
        && data.votes is int
        && data.votes >= 0
        && data.votes <= 10000000;
    }

    // 2. Votes collection
    match /votes/{characterId} {
      allow get, list: if true;
      allow create: if isValidId(characterId)
        && isValidVote(incoming())
        && (incoming().characterId == null || incoming().characterId == characterId)
        && (incoming().votes == 1 || incoming().votes == 0);
      allow update: if isValidId(characterId)
        && isValidVote(incoming())
        && (incoming().characterId == null || incoming().characterId == characterId)
        && (incoming().votes == existing().votes + 1 || incoming().votes == existing().votes - 1 || incoming().votes == existing().votes);
    }
  }
}
